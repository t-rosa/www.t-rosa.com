---
import Layout from "../layouts/Layout.astro";
---

<Layout title="t-rosa.com">
  <div class="h-screen grid grid-cols-1 grid-rows-[10rem_1fr_6rem]">
    <header class="border-b grid place-items-center">
      <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl">t-rosa.com</h1>
    </header>
    <main class="grid grid-rows-[1fr_auto_1fr] place-items-center">
      <h2 class="text-center text-3xl sm:text-4xl md:text-5xl lg:text-6xl">
        I build software for the web
      </h2>
      <p class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl">...</p>
      <div>
        <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl">
          Mainly with React
        </h2>
        <h3 class="text-center mt-3 text-zinc-400">
          but this one is built with Astro.
        </h3>
        <h4 class="text-center text-sm mt-1 text-zinc-400">
          sometimes I use solid.
        </h4>
        <h5 class="text-xs mt-1 text-zinc-400 text-center">even vanilla.</h5>
        <h6 class="text-[0.65rem] mt-1 text-zinc-400 text-center">sometimes.</h6>
      </div>
    </main>
    <footer
      class="border-t border-dashed flex items-center justify-center gap-6"
    >
      <a href="mailto:toma.rosa@protonmail.com" class="border rounded-full p-3">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><rect x="2" y="4" width="20" height="16" rx="2"></rect><path
            d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
        >
      </a>
      <a
        href="https://www.linkedin.com/in/toma-rosa"
        class="border rounded-full p-3"
      >
        <svg
          xmlns="
        http:
        www.w3.org
        2000
        svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
          ></path><rect x="2" y="9" width="4" height="12"></rect><circle
            cx="4"
            cy="4"
            r="2"></circle></svg
        >
      </a>
      <a href="https://github.com/t-rosa" class="border rounded-full p-3">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
          ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
        >
      </a>
    </footer>
  </div>
</Layout>
